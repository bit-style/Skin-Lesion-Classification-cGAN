          "# ROC curves (macro-average, Random Forest) A vs B\n",
          "best_idx = list(results_A['Model']).index(BEST)\n",
          "yte_bin = label_binarize(y_test, classes=classes_present)\n",
          "plt.figure(figsize=(7,6))\n",
          "for proba, tag, style in [(probas_A[BEST],'Model-A','--'), (probas_B[BEST],'Model-B','-')]:\n",
          "    fpr, tpr = {}, {}\n",
          "    for i in range(len(classes_present)):\n",
          "        fpr[i], tpr[i], _ = roc_curve(yte_bin[:, i], proba[:, i])\n",
          "    all_fpr = np.unique(np.concatenate([fpr[i] for i in range(len(classes_present))]))\n",
          "    mean_tpr = np.zeros_like(all_fpr)\n",
          "    for i in range(len(classes_present)):\n",
          "        mean_tpr += np.interp(all_fpr, fpr[i], tpr[i])\n",
          "    mean_tpr /= len(classes_present)\n",
          "    plt.plot(all_fpr, mean_tpr, style, label=f'{tag} (macro AUC={auc(all_fpr, mean_tpr):.3f})')\n",
          "plt.plot([0,1],[0,1],'k:'); plt.xlabel('False Positive Rate'); plt.ylabel('True Positive Rate')\n",
          "plt.title(f'Macro-average ROC — {BEST}'); plt.legend(); plt.tight_layout(); plt.show()"
