              "  vasc  : 114\n"
            ]
          }
        ],
        "source": [
          "X_train, X_test, y_train, y_test = train_test_split(\n",
          "    X, y, test_size=TEST_SIZE, stratify=y, random_state=RANDOM_STATE)\n",
          "\n",
          "print(\"Train:\", X_train.shape, \"| Test:\", X_test.shape)\n",
          "print(\"\\nTraining class counts:\")\n",
          "for i, name in enumerate(CLASS_NAMES):\n",
          "    print(f\"  {name:6s}: {(y_train==i).sum()}\")"
        ]
      },
      {
        "cell_type": "markdown",
        "id": "a2128d2b",
        "metadata": {
          "id": "a2128d2b"
        },
        "source": [
          "## 7. Helper: train the 4 classifiers and evaluate on the frozen test set\n",
          "We flatten images to 1-D vectors and scale to [0,1] — exactly the classical-ML pipeline from Assignment 3. This same function is reused for Model-A and Model-B."
        ]
      },
      {
        "cell_type": "code",
        "execution_count": null,
        "id": "3c79bd0d",
        "metadata": {
          "id": "3c79bd0d"
        },
        "outputs": [],
        "source": [
          "def to_features(imgs):\n",
          "    \"\"\"Flatten uint8 images (N,H,W,3) -> float vectors in [0,1].\"\"\"\n",
          "    return imgs.reshape(len(imgs), -1).astype('float32') / 255.0\n",
          "\n",
          "def get_models():\n",
          "    return {\n",
          "        'SVM':           SVC(probability=True, random_state=RANDOM_STATE),\n",
          "        'Decision Tree': DecisionTreeClassifier(random_state=RANDOM_STATE),\n",
          "        'Random Forest': RandomForestClassifier(n_estimators=100, random_state=RANDOM_STATE, n_jobs=-1),\n",
          "        'Naive Bayes':   GaussianNB(),\n",
          "    }\n",
          "\n",
          "def evaluate_all(Xtr_img, ytr, Xte_img, yte, tag=\"\"):\n",
          "    \"\"\"Train every model on (Xtr_img, ytr); evaluate on the frozen test set.\"\"\"\n",
          "    Xtr, Xte = to_features(Xtr_img), to_features(Xte_img)\n",
          "    rows, reports, probas = [], {}, {}\n",
          "    classes_present = np.unique(yte)\n",
          "    yte_bin = label_binarize(yte, classes=classes_present)\n",
          "    for name, model in get_models().items():\n",
          "        print(f\"  [{tag}] training {name} ...\")\n",
          "        model.fit(Xtr, ytr)\n",
          "        pred = model.predict(Xte)\n",
          "        proba = model.predict_proba(Xte)\n",
          "        # align proba columns to the test classes that exist\n",
          "        proba_aligned = np.zeros((len(yte), len(classes_present)))\n",
          "        for j, c in enumerate(classes_present):\n",
          "            if c in model.classes_:\n",
          "                proba_aligned[:, j] = proba[:, list(model.classes_).index(c)]\n",
          "        try:\n",
          "            mean_auc = roc_auc_score(yte_bin, proba_aligned, average='macro', multi_class='ovr')\n",
          "        except Exception:\n",
          "            mean_auc = np.nan\n",
          "        rows.append({\n",
          "            'Model': name,\n",
          "            'Accuracy':  accuracy_score(yte, pred),\n",
          "            'Precision': precision_score(yte, pred, average='weighted', zero_division=0),\n",
          "            'Recall':    recall_score(yte, pred, average='weighted', zero_division=0),\n",
          "            'F1-score':  f1_score(yte, pred, average='weighted', zero_division=0),\n",
          "            'Mean AUC':  mean_auc,\n",
          "        })\n",
          "        reports[name] = classification_report(\n",
          "            yte, pred, target_names=[CLASS_NAMES[c] for c in classes_present],\n",
          "            zero_division=0, output_dict=True)\n",
          "        probas[name] = proba_aligned\n",
          "    return pd.DataFrame(rows).round(4), reports, probas, classes_present"
        ]
      },
