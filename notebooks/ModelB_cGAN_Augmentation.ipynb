        "source": [
          "# Minority-class focus: per-class F1 before vs after (using the best model = Random Forest)\n",
          "BEST = 'Random Forest'\n",
          "def per_class_f1(reports):\n",
          "    return {c: reports[BEST][c]['f1-score'] for c in CLASS_NAMES if c in reports[BEST]}\n",
          "f1A, f1B = per_class_f1(reports_A), per_class_f1(reports_B)\n",
          "dfc = pd.DataFrame({'A': f1A, 'B': f1B})\n",
          "dfc['Δ'] = (dfc['B'] - dfc['A']).round(3)\n",
          "print(f\"Per-class F1 ({BEST}) — focus on minority classes df, vasc, akiec, mel:\")\n",
          "display(dfc.round(3))\n",
          "\n",
          "dfc[['A','B']].plot(kind='bar', figsize=(9,4))\n",
          "plt.title(f'Per-class F1: Model-A vs Model-B ({BEST})')\n",
          "plt.ylabel('F1-score'); plt.tight_layout(); plt.show()"
        ]
      },
