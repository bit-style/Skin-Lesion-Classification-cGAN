    "plt.figure(figsize=(8,4))\n",
    "order = meta['dx'].value_counts().index\n",
    "sns.countplot(data=meta, x='dx', order=order)\n",
    "plt.title('HAM10000 Class Distribution (severe imbalance)')\n",
    "plt.xlabel('Class'); plt.ylabel('Count')\n",
    "plt.tight_layout(); plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "925aceec",
   "metadata": {},
   "source": [
    "## 5. Load & preprocess images\n",
    "Resize to `IMG_SIZE`, keep RGB, store as uint8 arrays. We normalize later (differently for the GAN vs the classifiers)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d092a71e",
   "metadata": {},
   "outputs": [],
   "source": [
    "def load_image(path, size=IMG_SIZE):\n",
    "    img = cv2.imread(path)\n",
    "    img = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)\n",
    "    img = cv2.resize(img, (size, size))\n",
    "    return img\n",
    "\n",
    "print(\"Loading images... (this takes a few minutes)\")\n",
    "X = np.stack([load_image(p) for p in meta['path']]).astype('uint8')   # (N, H, W, 3)\n",
    "le = LabelEncoder().fit(CLASS_NAMES)\n",
    "y = le.transform(meta['dx'].values)\n",
    "print(\"X shape:\", X.shape, \"| y shape:\", y.shape)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "df263301",
   "metadata": {},
   "source": [
    "## 6. Stratified train/test split  ⚠️ critical step\n",
    "We split BEFORE any augmentation. The **test set is frozen** and shared by Model-A and Model-B. The GAN and all synthetic images are derived only from the **training** set."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "a4d6e036",
   "metadata": {},
   "outputs": [],
   "source": [
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X, y, test_size=TEST_SIZE, stratify=y, random_state=RANDOM_STATE)\n",
    "\n",
    "print(\"Train:\", X_train.shape, \"| Test:\", X_test.shape)\n",
    "print(\"\\nTraining class counts:\")\n",
    "for i, name in enumerate(CLASS_NAMES):\n",
    "    print(f\"  {name:6s}: {(y_train==i).sum()}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "a2128d2b",
   "metadata": {},
   "source": [
    "## 7. Helper: train the 4 classifiers and evaluate on the frozen test set\n",
    "We flatten images to 1-D vectors and scale to [0,1] — exactly the classical-ML pipeline from Assignment 3. This same function is reused for Model-A and Model-B."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "3c79bd0d",
   "metadata": {},
   "outputs": [],
   "source": [
    "def to_features(imgs):\n",
    "    \"\"\"Flatten uint8 images (N,H,W,3) -> float vectors in [0,1].\"\"\"\n",
    "    return imgs.reshape(len(imgs), -1).astype('float32') / 255.0\n",
    "\n",
    "def get_models():\n",
    "    return {\n",
    "        'SVM':           SVC(probability=True, random_state=RANDOM_STATE),\n",
    "        'Decision Tree': DecisionTreeClassifier(random_state=RANDOM_STATE),\n",
    "        'Random Forest': RandomForestClassifier(n_estimators=100, random_state=RANDOM_STATE, n_jobs=-1),\n",
    "        'Naive Bayes':   GaussianNB(),\n",
    "    }\n",
    "\n",
    "def evaluate_all(Xtr_img, ytr, Xte_img, yte, tag=\"\"):\n",
    "    \"\"\"Train every model on (Xtr_img, ytr); evaluate on the frozen test set.\"\"\"\n",
    "    Xtr, Xte = to_features(Xtr_img), to_features(Xte_img)\n",
    "    rows, reports, probas = [], {}, {}\n",
    "    classes_present = np.unique(yte)\n",
    "    yte_bin = label_binarize(yte, classes=classes_present)\n",
    "    for name, model in get_models().items():\n",
    "        print(f\"  [{tag}] training {name} ...\")\n",
    "        model.fit(Xtr, ytr)\n",
    "        pred = model.predict(Xte)\n",
    "        proba = model.predict_proba(Xte)\n",
    "        # align proba columns to the test classes that exist\n",
    "        proba_aligned = np.zeros((len(yte), len(classes_present)))\n",
    "        for j, c in enumerate(classes_present):\n",
    "            if c in model.classes_:\n",
    "                proba_aligned[:, j] = proba[:, list(model.classes_).index(c)]\n",
    "        try:\n",
    "            mean_auc = roc_auc_score(yte_bin, proba_aligned, average='macro', multi_class='ovr')\n",
    "        except Exception:\n",
    "            mean_auc = np.nan\n",
    "        rows.append({\n",
    "            'Model': name,\n",
    "            'Accuracy':  accuracy_score(yte, pred),\n",
    "            'Precision': precision_score(yte, pred, average='weighted', zero_division=0),\n",
    "            'Recall':    recall_score(yte, pred, average='weighted', zero_division=0),\n",
    "            'F1-score':  f1_score(yte, pred, average='weighted', zero_division=0),\n",
    "            'Mean AUC':  mean_auc,\n",
    "        })\n",
    "        reports[name] = classification_report(\n",
    "            yte, pred, target_names=[CLASS_NAMES[c] for c in classes_present],\n",
    "            zero_division=0, output_dict=True)\n",
    "        probas[name] = proba_aligned\n",
    "    return pd.DataFrame(rows).round(4), reports, probas, classes_present"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "f0b95dbe",
   "metadata": {},
   "source": [
    "## 8. Model-A (Baseline) — original training data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "75bd9db9",
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"===== MODEL-A (baseline) =====\")\n",
    "results_A, reports_A, probas_A, classes_present = evaluate_all(\n",
    "    X_train, y_train, X_test, y_test, tag=\"A\")\n",
    "print(\"\\nModel-A results:\")\n",
    "display(results_A)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "c9a5477f",
   "metadata": {},
   "source": [
    "## 9. Conditional GAN (cGAN)\n",
    "A label-conditioned DCGAN. The generator turns `(noise, class label)` into a 32×32 image; the discriminator judges `(image, class label)`. After training we sample the generator with specific labels to create synthetic minority-class images.\n",
    "\n",
    "Images are scaled to **[-1, 1]** here to match the generator's `tanh` output (this is separate from the [0,1] scaling used by the classifiers)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "c652a6a0",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ---- Dataset for the GAN (training images only, scaled to [-1,1]) ----\n",
    "from torch.utils.data import TensorDataset, DataLoader\n",
    "\n",
    "X_gan = (torch.tensor(X_train).permute(0,3,1,2).float() / 127.5) - 1.0   # (N,3,H,W) in [-1,1]\n",
    "y_gan = torch.tensor(y_train).long()\n",
    "gan_loader = DataLoader(TensorDataset(X_gan, y_gan), batch_size=GAN_BATCH,\n",
    "                        shuffle=True, drop_last=True)\n",
    "print(\"GAN training tensors:\", X_gan.shape)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e571f830",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ---- Generator ----\n",
    "class Generator(nn.Module):\n",
    "    def __init__(self, z_dim=Z_DIM, n_classes=N_CLASSES, img_ch=3, fg=64, emb=50):\n",
    "        super().__init__()\n",
    "        self.label_emb = nn.Embedding(n_classes, emb)\n",
    "        self.net = nn.Sequential(\n",
    "            nn.ConvTranspose2d(z_dim + emb, fg*4, 4, 1, 0, bias=False),  # ->4x4\n",
    "            nn.BatchNorm2d(fg*4), nn.ReLU(True),\n",
    "            nn.ConvTranspose2d(fg*4, fg*2, 4, 2, 1, bias=False),          # ->8x8\n",
    "            nn.BatchNorm2d(fg*2), nn.ReLU(True),\n",
    "            nn.ConvTranspose2d(fg*2, fg,   4, 2, 1, bias=False),          # ->16x16\n",
    "            nn.BatchNorm2d(fg),   nn.ReLU(True),\n",
    "            nn.ConvTranspose2d(fg, img_ch, 4, 2, 1, bias=False),          # ->32x32\n",
    "            nn.Tanh(),\n",
    "        )\n",
    "    def forward(self, z, labels):\n",
    "        c = self.label_emb(labels)                       # (B, emb)\n",
    "        x = torch.cat([z, c], dim=1).unsqueeze(-1).unsqueeze(-1)  # (B, z+emb, 1, 1)\n",
    "        return self.net(x)\n",
    "\n",
    "# ---- Discriminator ----\n",
    "class Discriminator(nn.Module):\n",
    "    def __init__(self, n_classes=N_CLASSES, img_ch=3, fd=64, size=IMG_SIZE):\n",
    "        super().__init__()\n",
    "        self.size = size\n",
    "        self.label_emb = nn.Embedding(n_classes, size*size)   # label -> 1 image-sized channel\n",
    "        self.net = nn.Sequential(\n",
    "            nn.Conv2d(img_ch+1, fd,   4, 2, 1, bias=False), nn.LeakyReLU(0.2, True),  # ->16\n",
    "            nn.Conv2d(fd, fd*2, 4, 2, 1, bias=False), nn.BatchNorm2d(fd*2), nn.LeakyReLU(0.2, True),  # ->8\n",
    "            nn.Conv2d(fd*2, fd*4, 4, 2, 1, bias=False), nn.BatchNorm2d(fd*4), nn.LeakyReLU(0.2, True), # ->4\n",
    "            nn.Conv2d(fd*4, 1, 4, 1, 0, bias=False), nn.Sigmoid(),                    # ->1\n",
    "        )\n",
    "    def forward(self, img, labels):\n",
    "        c = self.label_emb(labels).view(-1, 1, self.size, self.size)\n",
    "        x = torch.cat([img, c], dim=1)\n",
    "        return self.net(x).view(-1)\n",
    "\n",
    "G = Generator().to(device)\n",
    "D = Discriminator().to(device)\n",
    "print(G); print(D)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "3aaa7c31",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ---- Train the cGAN ----\n",
    "criterion = nn.BCELoss()\n",
    "optG = torch.optim.Adam(G.parameters(), lr=2e-4, betas=(0.5, 0.999))\n",
    "optD = torch.optim.Adam(D.parameters(), lr=2e-4, betas=(0.5, 0.999))\n",
    "\n",
    "g_hist, d_hist = [], []\n",
    "for epoch in range(GAN_EPOCHS):\n",
    "    g_run = d_run = 0.0\n",
    "    for real, labels in gan_loader:\n",
    "        real, labels = real.to(device), labels.to(device)\n",
    "        bs = real.size(0)\n",
    "        real_lbl = torch.full((bs,), 0.9, device=device)   # label smoothing\n",
    "        fake_lbl = torch.zeros(bs, device=device)\n",
    "\n",
    "        # --- train D ---\n",
    "        optD.zero_grad()\n",
    "        d_real = D(real, labels)\n",
    "        loss_real = criterion(d_real, real_lbl)\n",
    "        z = torch.randn(bs, Z_DIM, device=device)\n",
    "        gen_labels = torch.randint(0, N_CLASSES, (bs,), device=device)\n",
    "        fake = G(z, gen_labels)\n",
    "        d_fake = D(fake.detach(), gen_labels)\n",
    "        loss_fake = criterion(d_fake, fake_lbl)\n",
    "        lossD = loss_real + loss_fake\n",
    "        lossD.backward(); optD.step()\n",
    "\n",
    "        # --- train G ---\n",
    "        optG.zero_grad()\n",
    "        out = D(fake, gen_labels)\n",
    "        lossG = criterion(out, torch.ones(bs, device=device))\n",
    "        lossG.backward(); optG.step()\n",
    "\n",
    "        g_run += lossG.item(); d_run += lossD.item()\n",
    "    g_hist.append(g_run/len(gan_loader)); d_hist.append(d_run/len(gan_loader))\n",
    "    if (epoch+1) % 5 == 0 or epoch == 0:\n",
    "        print(f\"Epoch {epoch+1:3d}/{GAN_EPOCHS} | D_loss {d_hist[-1]:.3f} | G_loss {g_hist[-1]:.3f}\")\n",
    "\n",
    "plt.plot(g_hist, label='Generator'); plt.plot(d_hist, label='Discriminator')\n",
    "plt.xlabel('Epoch'); plt.ylabel('Loss'); plt.legend(); plt.title('cGAN training losses'); plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5de518ee",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ---- Inspect generated samples per class ----\n",
    "G.eval()\n",
    "fig, axes = plt.subplots(N_CLASSES, 6, figsize=(9, 1.6*N_CLASSES))\n",
    "with torch.no_grad():\n",
    "    for ci, name in enumerate(CLASS_NAMES):\n",
    "        z = torch.randn(6, Z_DIM, device=device)\n",
    "        lbls = torch.full((6,), ci, device=device, dtype=torch.long)\n",
    "        imgs = G(z, lbls).cpu().permute(0,2,3,1).numpy()\n",
    "        imgs = ((imgs + 1) * 127.5).clip(0,255).astype('uint8')\n",
    "        for j in range(6):\n",
    "            axes[ci, j].imshow(imgs[j]); axes[ci, j].axis('off')\n",
    "        axes[ci, 0].set_ylabel(name, rotation=0, labelpad=25, fontsize=11)\n",
    "plt.suptitle('Synthetic images generated by the cGAN (per class)')\n",
    "plt.tight_layout(); plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "0c295c77",
   "metadata": {},
   "source": [
    "## 10. Generate synthetic images & build the augmented training set\n",
    "For every class whose training count is below `TARGET_PER_CLASS`, we generate enough synthetic images to reach the target. The majority class (`nv`) is left as-is. Synthetic images are added ONLY to the training set."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "7990e1cd",
   "metadata": {},
   "outputs": [],
   "source": [
    "def generate_for_class(class_idx, n):\n",
    "    \"\"\"Generate n synthetic uint8 images (n,H,W,3) for one class.\"\"\"\n",
    "    G.eval()\n",
    "    out = []\n",
    "    with torch.no_grad():\n",
    "        for start in range(0, n, 256):\n",
    "            b = min(256, n - start)\n",
    "            z = torch.randn(b, Z_DIM, device=device)\n",
    "            lbls = torch.full((b,), class_idx, device=device, dtype=torch.long)\n",
    "            imgs = G(z, lbls).cpu().permute(0,2,3,1).numpy()\n",
    "            imgs = ((imgs + 1) * 127.5).clip(0,255).astype('uint8')\n",
    "            out.append(imgs)\n",
    "    return np.concatenate(out)\n",
    "\n",
    "synth_X, synth_y = [], []\n",
    "print(\"Generating synthetic images:\")\n",
    "for ci, name in enumerate(CLASS_NAMES):\n",
    "    have = (y_train == ci).sum()\n",
    "    need = max(0, TARGET_PER_CLASS - have)\n",
    "    if need > 0:\n",
    "        synth_X.append(generate_for_class(ci, need))\n",
    "        synth_y.append(np.full(need, ci))\n",
