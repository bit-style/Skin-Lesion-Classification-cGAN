        "source": [
          "## 9. Conditional GAN (cGAN)\n",
          "A label-conditioned DCGAN. The generator turns `(noise, class label)` into a 32×32 image; the discriminator judges `(image, class label)`. After training we sample the generator with specific labels to create synthetic minority-class images.\n",
          "\n",
          "Images are scaled to **[-1, 1]** here to match the generator's `tanh` output (this is separate from the [0,1] scaling used by the classifiers)."
        ]
      },
      {
        "cell_type": "code",
        "execution_count": null,
        "id": "c652a6a0",
        "metadata": {
          "id": "c652a6a0"
        },
        "outputs": [],
        "source": [
          "# ---- Dataset for the GAN (training images only, scaled to [-1,1]) ----\n",
          "from torch.utils.data import TensorDataset, DataLoader\n",
          "\n",
          "X_gan = (torch.tensor(X_train).permute(0,3,1,2).float() / 127.5) - 1.0   # (N,3,H,W) in [-1,1]\n",
          "y_gan = torch.tensor(y_train).long()\n",
          "gan_loader = DataLoader(TensorDataset(X_gan, y_gan), batch_size=GAN_BATCH,\n",
          "                        shuffle=True, drop_last=True)\n",
          "print(\"GAN training tensors:\", X_gan.shape)"
        ]
      },
      {
        "cell_type": "code",
        "execution_count": null,
        "id": "e571f830",
        "metadata": {
          "id": "e571f830"
        },
        "outputs": [],
        "source": [
          "# ---- Generator ----\n",
          "class Generator(nn.Module):\n",
          "    def __init__(self, z_dim=Z_DIM, n_classes=N_CLASSES, img_ch=3, fg=64, emb=50):\n",
          "        super().__init__()\n",
          "        self.label_emb = nn.Embedding(n_classes, emb)\n",
          "        self.net = nn.Sequential(\n",
          "            nn.ConvTranspose2d(z_dim + emb, fg*4, 4, 1, 0, bias=False),  # ->4x4\n",
          "            nn.BatchNorm2d(fg*4), nn.ReLU(True),\n",
          "            nn.ConvTranspose2d(fg*4, fg*2, 4, 2, 1, bias=False),          # ->8x8\n",
          "            nn.BatchNorm2d(fg*2), nn.ReLU(True),\n",
          "            nn.ConvTranspose2d(fg*2, fg,   4, 2, 1, bias=False),          # ->16x16\n",
          "            nn.BatchNorm2d(fg),   nn.ReLU(True),\n",
          "            nn.ConvTranspose2d(fg, img_ch, 4, 2, 1, bias=False),          # ->32x32\n",
          "            nn.Tanh(),\n",
          "        )\n",
          "    def forward(self, z, labels):\n",
          "        c = self.label_emb(labels)                       # (B, emb)\n",
          "        x = torch.cat([z, c], dim=1).unsqueeze(-1).unsqueeze(-1)  # (B, z+emb, 1, 1)\n",
          "        return self.net(x)\n",
          "\n",
          "# ---- Discriminator ----\n",
          "class Discriminator(nn.Module):\n",
          "    def __init__(self, n_classes=N_CLASSES, img_ch=3, fd=64, size=IMG_SIZE):\n",
          "        super().__init__()\n",
          "        self.size = size\n",
          "        self.label_emb = nn.Embedding(n_classes, size*size)   # label -> 1 image-sized channel\n",
          "        self.net = nn.Sequential(\n",
          "            nn.Conv2d(img_ch+1, fd,   4, 2, 1, bias=False), nn.LeakyReLU(0.2, True),  # ->16\n",
          "            nn.Conv2d(fd, fd*2, 4, 2, 1, bias=False), nn.BatchNorm2d(fd*2), nn.LeakyReLU(0.2, True),  # ->8\n",
          "            nn.Conv2d(fd*2, fd*4, 4, 2, 1, bias=False), nn.BatchNorm2d(fd*4), nn.LeakyReLU(0.2, True), # ->4\n",
          "            nn.Conv2d(fd*4, 1, 4, 1, 0, bias=False), nn.Sigmoid(),                    # ->1\n",
          "        )\n",
          "    def forward(self, img, labels):\n",
          "        c = self.label_emb(labels).view(-1, 1, self.size, self.size)\n",
          "        x = torch.cat([img, c], dim=1)\n",
          "        return self.net(x).view(-1)\n",
          "\n",
          "G = Generator().to(device)\n",
          "D = Discriminator().to(device)\n",
          "print(G); print(D)"
        ]
      },
      {
