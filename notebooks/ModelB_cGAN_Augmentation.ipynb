        "source": [
          "## 10. Generate synthetic images & build the augmented training set\n",
          "For every class whose training count is below `TARGET_PER_CLASS`, we generate enough synthetic images to reach the target. The majority class (`nv`) is left as-is. Synthetic images are added ONLY to the training set."
        ]
      },
      {
        "cell_type": "code",
        "execution_count": null,
        "id": "7990e1cd",
        "metadata": {
          "colab": {
            "base_uri": "https://localhost:8080/"
          },
          "executionInfo": {
            "elapsed": 10,
            "status": "ok",
            "timestamp": 1780854968624,
            "user": {
              "displayName": "dark screen 111",
              "userId": "17549057031985081783"
            },
            "user_tz": -180
          },
          "id": "7990e1cd",
          "outputId": "d771e306-455a-414f-e835-8b45ce92043a"
        },
        "outputs": [
          {
            "name": "stdout",
            "output_type": "stream",
            "text": [
              "Generating synthetic images:\n",
              "  akiec : had   262, generated   738  -> 1000\n",
              "  bcc   : had   411, generated   589  -> 1000\n",
              "  bkl   : had   879, generated   121  -> 1000\n",
              "  df    : had    92, generated   908  -> 1000\n",
              "  mel   : had   890, generated   110  -> 1000\n",
              "  nv    : had  5364, generated     0  (already >= target)\n",
              "  vasc  : had   114, generated   886  -> 1000\n",
              "\n",
              "Augmented training set: (11364, 32, 32, 3)\n"
            ]
          }
        ],
        "source": [
          "def generate_for_class(class_idx, n):\n",
          "    \"\"\"Generate n synthetic uint8 images (n,H,W,3) for one class.\"\"\"\n",
          "    G.eval()\n",
          "    out = []\n",
          "    with torch.no_grad():\n",
          "        for start in range(0, n, 256):\n",
          "            b = min(256, n - start)\n",
          "            z = torch.randn(b, Z_DIM, device=device)\n",
          "            lbls = torch.full((b,), class_idx, device=device, dtype=torch.long)\n",
          "            imgs = G(z, lbls).cpu().permute(0,2,3,1).numpy()\n",
          "            imgs = ((imgs + 1) * 127.5).clip(0,255).astype('uint8')\n",
          "            out.append(imgs)\n",
          "    return np.concatenate(out)\n",
          "\n",
          "synth_X, synth_y = [], []\n",
          "print(\"Generating synthetic images:\")\n",
          "for ci, name in enumerate(CLASS_NAMES):\n",
          "    have = (y_train == ci).sum()\n",
          "    need = max(0, TARGET_PER_CLASS - have)\n",
          "    if need > 0:\n",
          "        synth_X.append(generate_for_class(ci, need))\n",
          "        synth_y.append(np.full(need, ci))\n",
          "        print(f\"  {name:6s}: had {have:5d}, generated {need:5d}  -> {have+need}\")\n",
          "    else:\n",
          "        print(f\"  {name:6s}: had {have:5d}, generated     0  (already >= target)\")\n",
          "\n",
          "if synth_X:\n",
          "    synth_X = np.concatenate(synth_X); synth_y = np.concatenate(synth_y)\n",
          "    X_train_aug = np.concatenate([X_train, synth_X])\n",
          "    y_train_aug = np.concatenate([y_train, synth_y])\n",
          "else:\n",
          "    X_train_aug, y_train_aug = X_train, y_train\n",
          "\n",
          "print(\"\\nAugmented training set:\", X_train_aug.shape)"
        ]
      },
