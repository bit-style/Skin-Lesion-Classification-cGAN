        "source": [
          "# Side-by-side overall metrics\n",
          "cmp = results_A.merge(results_B, on='Model', suffixes=(' (A)', ' (B)'))\n",
          "metric_cols = ['Accuracy', 'Precision', 'Recall', 'F1-score', 'Mean AUC']\n",
          "for m in metric_cols:\n",
          "    cmp[f'{m} Δ'] = (cmp[f'{m} (B)'] - cmp[f'{m} (A)']).round(4)\n",
          "display(cmp)"
        ]
      },
